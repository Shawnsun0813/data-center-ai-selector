# Environment variables for the Data Center Site Selection Pipeline
#
# How to use:
# 1. Copy this file to .env in the same directory
# 2. Add your actual API keys
# 3. Load with: python-dotenv (pip install python-dotenv) 
#    or set environment variables manually in your shell

# ─────────────────────────────────────────────────────
# EIA API KEY (U.S. Energy Information Administration)
# Required for: power_capacity.py, carbon_intensity.py
# Sign up FREE at: https://www.eia.gov/opendata/
# ─────────────────────────────────────────────────────
EIA_API_KEY=your_eia_api_key_here

# ─────────────────────────────────────────────────────
# NO KEY REQUIRED FOR:
#   - Open-Meteo (weather_pue.py)
#   - OpenStreetMap / Overpass API (osm_proximity.py)
#   - FEMA National Risk Index ArcGIS (disaster_risk.py)
#   - USGS Water Services (water_access.py)
# ─────────────────────────────────────────────────────
